{
  "version": "26.601.2237.0",
  "description": "Unofficial Windows ARM64 repackaging of the OpenAI Codex app.",
  "homepage": "https://github.com/airtaxi/codex-app-windows-arm64",
  "license": "MIT",
  "architecture": {
    "arm64": {
      "url": "https://github.com/airtaxi/codex-app-windows-arm64/releases/download/26.601.2237/dist.7z",
      "hash": "03abd00f7b0e94c1e59b1c8bad2328cc9fd8db56ca9a7595a9a125069e085927"
    }
  },
  "installer": {
    "script": [
      "$msix = Get-ChildItem -LiteralPath $dir -Filter \"Codex-WoA_*_arm64.msix\" | Select-Object -First 1",
      "$cer = Join-Path $dir \"CodexWoA.cer\"",
      "if (-not $msix) { throw \"Codex WoA MSIX not found.\" }",
      "if (-not (Test-Path -LiteralPath $cer)) { $cer = Join-Path $dir \"cert\\CodexWoA.cer\" }",
      "Write-Host \"Force-stopping running Codex WoA package processes before MSIX install...\"",
      "$codexPackages = @(Get-AppxPackage -Name \"OpenAI.Codex.WoA\" -ErrorAction SilentlyContinue)",
      "$codexInstallLocations = @($codexPackages | Where-Object { -not [string]::IsNullOrWhiteSpace($_.InstallLocation) } | ForEach-Object { [System.IO.Path]::GetFullPath($_.InstallLocation).TrimEnd([System.IO.Path]::DirectorySeparatorChar, [System.IO.Path]::AltDirectorySeparatorChar) })",
      "$codexProcesses = @()",
      "foreach ($process in Get-Process -ErrorAction SilentlyContinue) {",
      "  $processPath = $null",
      "  try { $processPath = $process.Path } catch { }",
      "  if ([string]::IsNullOrWhiteSpace($processPath)) { continue }",
      "  foreach ($location in $codexInstallLocations) {",
      "    if ($processPath.StartsWith($location, [System.StringComparison]::OrdinalIgnoreCase)) { $codexProcesses += $process; break }",
      "  }",
      "}",
      "if ($codexProcesses.Count -gt 0) { $codexProcesses | Stop-Process -Force -ErrorAction SilentlyContinue; $codexProcesses | Wait-Process -Timeout 10 -ErrorAction SilentlyContinue }",
      "& (Join-Path $dir \"Install.ps1\") -MsixPath $msix.FullName -CerPath $cer",
      "if ($LASTEXITCODE) { exit $LASTEXITCODE }"
    ]
  },
  "notes": "Install.ps1 imports the included local signing certificate into TrustedPeople and may request elevation."
}
